
.container {
  padding: 80rpx 48rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
}

.options {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

.option {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s;
}

.option.selected {
  border-color: #1a1a1a;
  background: #f8f8f8;
}

.emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.label {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 26rpx;
  color: #999;
}

.btn {
  background: #1a1a1a;
  color: #fff;
  padding: 32rpx 120rpx;
  border-radius: 100rpx;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}

